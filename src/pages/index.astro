---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/AboutSection.astro";
import PujoOverYears from "../components/PujoOverYears.astro";
import ContributeSection from "../components/ContributeSection.astro";
import SponsorsSection from "../components/SponsorsSection.astro";
---

<Layout title="Shriram Samruddhi Pujo 2026">
    <main>
        <div
            style="text-align: center; max-width: 600px; margin: 0 auto; padding: 12rem 2rem 2rem;"
        >
            <h1
                style="font-size: clamp(2.6rem, 8vw, 5rem); margin-bottom: 2rem; color: #b13321; line-height: 1.02; letter-spacing: -.015em;"
            >
                Shriram Samruddhi Durga Pujo
            </h1>
            <p
                style="font-size: 1.25rem; line-height: 1.6; color: #444; margin-bottom: 2rem;"
            >
                <strong>COMING SOON</strong>
            </p>
        </div>

        <AboutSection />
        <PujoOverYears />
        <ContributeSection />
        <SponsorsSection />
    </main>
</Layout>
