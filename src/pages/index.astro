---
import Layout from '../layouts/Layout.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
---
<Layout title="Shriram Samruddhi Pujo 2026">
	<main style="display: flex; flex-direction: column; justify-content: center; min-height: 100vh; padding: 2rem 0; box-sizing: border-box; gap: 3rem;">
		<div style="text-align: center; max-width: 600px; margin: 0 auto; padding: 0 2rem;">
			<h1 style="font-size: clamp(2.6rem, 8vw, 5rem); margin-bottom: 0.5rem; color: #b13321; line-height: 1.02; letter-spacing: -.015em;">
				Shriram Samruddhi Durga Pujo
			</h1>
			<p style="font-size: 1.25rem; line-height: 1.6; color: #444; margin-bottom: 2rem;">
				<strong>COMING SOON</strong>
			</p>
		</div>
		<ImageCarousel />
	</main>
</Layout>
