---
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';
import headerTopAlpona from '../assets/images/header-top-alpona.svg';
import headerBaseAlpona from '../assets/images/header-base-alpona.svg';
import iconLogo from '../assets/images/icon-on-dark-bg.svg';

const navLinks = [
  { label: "Home",    href: "/" },
  { label: "About",   href: "/about" },
  { label: "Events",  href: "/events" },
  { label: "Gallery", href: "/gallery" },
  { label: "Contact", href: "/contact" },
];
---

<div class="sticky top-0 z-50 w-full">
<header class="w-full relative" style="background: var(--palette-crimson);">
  <!--
  <div
    class="header-alpona"
    style={`background-image: url(${headerTopAlpona.src});`}
    role="presentation"
    aria-hidden="true"
  ></div>
  -->

  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">

    <!-- Logomark -->
    <a href="/" class="flex items-center leading-tight no-underline" aria-label="SSDPA Home">
      <img src={iconLogo.src} alt="SSDPA" class="h-10 w-auto sm:h-11" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a href={href} class="text-[16px] font-medium header-link transition-colors duration-150">
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle navigation menu"
      class={cn(
        buttonVariants({ variant: 'ghost', size: 'icon' }),
        'md:hidden header-link hover:bg-white/10 [&_svg]:size-5'
      )}
    >
      <Menu id="icon-menu" size={22} />
      <X id="icon-close" size={22} class="hidden" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    hidden
    class="md:hidden absolute top-full left-0 w-full shadow-lg px-4 pb-4 header-mobile-menu"
    style="background: var(--palette-crimson);"
  >
    <nav class="flex flex-col gap-1 pt-2" aria-label="Mobile navigation">
      {navLinks.map(({ label, href }) => (
        <a href={href} class="rounded-md px-3 py-2.5 text-sm font-medium header-link hover:bg-white/10 transition-colors duration-150">
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<div
  class="header-base-alpona"
  style={`background-image: url(${headerBaseAlpona.src});`}
  role="presentation"
  aria-hidden="true"
></div>
</div>

<style>
  .header-link         { color: var(--palette-cream); }
  .header-link:hover   { color: var(--palette-gold); }
  .header-link:focus-visible {
    color: var(--palette-gold);
    outline: 2px solid var(--palette-gold);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .header-mobile-menu { border-top: 1px solid oklch(1 0 0 / 20%); }

  .header-alpona {
    width: 100%;
    height: clamp(0.55rem, 0.8vw, 0.625rem);
    background-repeat: repeat-x;
    background-position: top left;
    background-size: auto 100%;
  }

  .header-base-alpona {
    width: 100%;
    height: clamp(2rem, 3.2vw, 2.75rem);
    background-repeat: repeat-x;
    background-position: top left;
    background-size: auto 100%;
  }
</style>

<script>
  const toggle    = document.getElementById("menu-toggle")!;
  const menu      = document.getElementById("mobile-menu")!;
  const iconMenu  = document.getElementById("icon-menu")!;
  const iconClose = document.getElementById("icon-close")!;

  toggle.addEventListener("click", () => {
    const isOpen = !menu.hidden;
    menu.hidden = isOpen;
    toggle.setAttribute("aria-expanded", String(!isOpen));
    iconMenu.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768 && !menu.hidden) {
      menu.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
    }
  });
</script>
