---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';
import ImageCarousel from '@/components/ImageCarousel.astro';
---

<section id="our-journey" class="py-16 sm:py-20" style="background: var(--palette-cream-dk);">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold tracking-wide uppercase" style="color: var(--palette-gold);">
        Through the Years
      </p>
      <h2 class="mb-5 text-3xl sm:text-4xl" style="color: var(--palette-crimson);">
        Durga Puja Over the Years
      </h2>
      <p class="text-base leading-relaxed sm:text-lg" style="color: var(--muted-foreground);">
        Placeholder copy — a glimpse of the moments, faces, and festivities from Pujos
        past, from the very first celebration to last year's.
      </p>
    </div>
  </div>

  <div class="mt-10">
    <ImageCarousel />
  </div>

  <div class="mt-4 text-center">
    <a href="/history" class={cn(buttonVariants({ variant: 'default', size: 'lg' }))}>
      Explore Our Journey
      <ArrowRight size={18} />
    </a>
  </div>
</section>
